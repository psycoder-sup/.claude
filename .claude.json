{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd",
        "--context",
        "claude-code",
        "--open-web-dashboard",
        "False"
      ]
    },
    "headroom": {
      "command": "headroom",
      "args": [
        "mcp",
        "serve"
      ]
    }
  }
}
